# Required: your Anthropic API key (https://console.anthropic.com)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
LIFELENS_MODEL=claude-sonnet-4-6
LIFELENS_CHAT_MODEL=claude-opus-4-8

# Comma-separated origins allowed to call the API (no trailing slash)
LIFELENS_CORS_ORIGINS=http://localhost:5173

# Rate limiting, per client IP. The burst window stops rapid-fire abuse; the
# sustained window caps longer-run use. Whichever trips first returns 429.
LIFELENS_BURST_LIMIT=5        # max requests per burst window
LIFELENS_BURST_WINDOW=60      # burst window, seconds
LIFELENS_RATE_LIMIT=20        # max requests per sustained window
LIFELENS_RATE_WINDOW=3600     # sustained window, seconds

# Cost circuit breaker: max upstream model calls per UTC day across all callers.
# Set a hard spend limit in the Anthropic console too; that is the real backstop.
LIFELENS_DAILY_BUDGET=1000
